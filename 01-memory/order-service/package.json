{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Order management microservice — Fastify + TypeScript + Prisma",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.15.0",
    "vitest": "^1.6.0",
    "eslint": "^9.5.0",
    "prisma": "^5.15.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
